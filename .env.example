# Environment Variables for TOB Parser
#
# For LOCAL development: copy this file to .env and fill in your values.
# For Vercel: set these in Dashboard → Settings → Environment Variables.
# For Claude Cowork: set VITE_GITHUB_TOKEN as an environment variable in the session.
#
# IMPORTANT: The variable name must be exactly VITE_GITHUB_TOKEN (Vite only
# exposes env vars with the VITE_ prefix to the browser bundle).

# GitHub Personal Access Token — used for triggering the Deep Scan workflow.
# Generate at: https://github.com/settings/tokens
# Required scopes (Fine-grained token): Actions → Read & Write, Contents → Read
VITE_GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Optional: Google Sheets URL for cloud scan result sync.
# Set as a GitHub Actions Secret named GOOGLE_SHEETS_URL (not Vercel).
# GOOGLE_SHEETS_URL=https://script.google.com/macros/s/xxx/exec
