# Vercel Environment Variables for TOB Parser

# GitHub Personal Access Token — used for triggering the Deep Scan workflow
# Generate at: https://github.com/settings/tokens → Fine-grained → Actions: Read & Write
# Set this in Vercel: Dashboard → Settings → Environment Variables
VITE_GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Optional: Google Sheets URL for cloud scan result sync
# Set as a GitHub Actions Secret (not Vercel)
# GOOGLE_SHEETS_URL=https://script.google.com/macros/s/xxx/exec
