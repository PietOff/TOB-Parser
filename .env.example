# ──────────────────────────────────────────────────────────────────────────────
# TOB Parser — Environment Variables
# ──────────────────────────────────────────────────────────────────────────────
# Kopieer dit bestand naar .env.local voor lokale ontwikkeling.
# Voor Vercel: stel deze variabelen in via Dashboard > Project Settings > Environment Variables.
# BELANGRIJK: Vite exposeert alleen variabelen met het VITE_ prefix naar de browser bundle.
# ──────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Vereist voor authenticatie en databaseoperaties.
# Vind deze waarden in: Supabase Dashboard > Project > Settings > API
VITE_SUPABASE_URL=https://jouw-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=jouw-anon-public-key-hier

# ── GitHub Token (optioneel) ──────────────────────────────────────────────────
# Gebruikt voor het triggeren van de Deep Scan workflow.
# Genereer via: GitHub > Settings > Developer Settings > Personal Access Tokens
# Vereiste permissies: Actions (read/write), Contents (read/write)
VITE_GITHUB_TOKEN=ghp_jouw_token_hier

# ── Google Sheets (optioneel) ─────────────────────────────────────────────────
# Voor cloud sync van scan-resultaten.
# Configureer als GitHub Actions Secret, NIET via Vercel.
# GOOGLE_SHEETS_CREDENTIALS={"type":"service_account",...}
